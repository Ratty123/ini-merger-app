{
  "name": "ini-merger-app",
  "version": "2.4.0",
  "description": "A secure desktop tool for merging Unreal-style INI files with cleanup controls, structural validation, bulk duplicate actions, autosaved sessions, and an editor-style live preview.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "dist": "npm test && electron-builder --win portable"
  },
  "build": {
    "appId": "com.ini.merger",
    "productName": "INI Merger",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "build/**/*",
      "src/**/*",
      "LICENSE"
    ],
    "icon": "icon.ico",
    "portable": {
      "artifactName": "INIMerger-${version}.exe"
    },
    "win": {
      "icon": "icon.ico",
      "target": [
        "portable"
      ]
    }
  },
  "keywords": [
    "electron",
    "ini",
    "unreal-engine",
    "merge-tool",
    "config-editor"
  ],
  "author": "Ratty123",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.0.12"
  }
}
